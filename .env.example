# ─────────────────────────────────────────────────────────────
# Zkopíruj tento soubor do `.env` a vyplň hodnoty.
# `.env` je v .gitignore — necommituj ho.
# Next.js i drizzle-kit (přes dotenv) čtou ze stejného `.env`.
# ─────────────────────────────────────────────────────────────

# --- Databáze (Supabase Postgres) ---
# Connection stringy vezmi z dashboardu Supabase: Project → Connect.
# Heslo se speciálními znaky (@, :, /) musí být v URL percent-encodované (@ -> %40).
# POZOR na dva různé porty (stejný pooler host):
#   DATABASE_URL = Transaction pooler, port 6543 (běžné dotazy z appky)
#   DIRECT_URL   = Session pooler, port 5432 (migrace přes drizzle-kit)
# Pozn.: "Direct connection" (db.<ref>.supabase.co) je IPv6-only a z IPv4 sítí
# se nepřeloží — proto pro migrace používáme session pooler (5432), ne direct.
DATABASE_URL="postgresql://postgres.<ref>:<heslo>@aws-1-<region>.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.<ref>:<heslo>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Claude (generování draftů) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Resend (odesílání e-mailů) ---
RESEND_API_KEY=
# Odesílatel musí být na ověřené doméně v Resendu.
MAIL_FROM="Jméno <ahoj@tvojedomena.cz>"
# Signing secret z Resend webhooku (Dashboard → Webhooks). Začíná „whsec_".
# Bez něj endpoint /api/resend/webhook vrací 503 (tracking se neaktualizuje).
RESEND_WEBHOOK_SECRET=

# --- Veřejná URL appky (odhlašovací odkazy v e-mailech) ---
# Např. https://tak.itakk.cz . Když chybí, použije se localhost (jen dev).
APP_URL=
# Volitelný vlastní secret pro podpis odhlašovacích odkazů; jinak se použije
# APP_SESSION_TOKEN / CRON_SECRET.
UNSUBSCRIBE_SECRET=

# --- Google Places API (hodnocení leadů; VOLITELNÉ) ---
# Když je prázdné, obohacení o hodnocení se přeskočí (ARES běží i bez něj).
# Places má měsíční kredit zdarma; pro desítky leadů se do něj vejdeš.
GOOGLE_PLACES_API_KEY=

# --- PageSpeed Insights API (volitelné; když chybí, pagespeed = null) ---
PAGESPEED_API_KEY=

# --- Overpass proxy (discovery z Vercelu) ---
# Veřejný Overpass blokuje AWS/Vercel IP → discovery na Vercelu padá (504/
# fetch failed). Nasaď Cloudflare Worker (viz cloudflare/overpass-worker.js)
# a vyplň URL + secret. Lokálně necháš prázdné (jde přímo na mirrory).
OVERPASS_PROXY_URL=
OVERPASS_PROXY_SECRET=

# --- Vercel (přehled projektů; volitelné) ---
# Token: vercel.com/account/tokens (read-only stačí). U týmu vyplň i VERCEL_TEAM_ID.
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# --- Telegram bot (webhook) ---
TELEGRAM_BOT_TOKEN=
# Náhodný tajný řetězec; posílá se Telegramu při registraci webhooku
# a ověřuje se v hlavičce X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
# Tvoje chat_id (whitelist pro bota). Uloží se i do app_user při seedu.
TELEGRAM_ALLOWED_CHAT_ID=

# --- Přihlášení do appky ---
# Heslo k appce. Když je prázdné, login je VYPNUTÝ (appka veřejná).
APP_PASSWORD=
# Náhodný dlouhý token (openssl rand -hex 24) — hodnota session cookie.
APP_SESSION_TOKEN=
# Tajný token pro cron endpoint (Telegram denní souhrn).
CRON_SECRET=

# --- Web Push notifikace (PWA na telefon) ---
# Vygeneruj: npx web-push generate-vapid-keys --json
# Public key musí být NEXT_PUBLIC_ (jde do prohlížeče). Subject = mailto: kontakt.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
