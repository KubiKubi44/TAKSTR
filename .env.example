# ─────────────────────────────────────────────────────────────
# Zkopíruj tento soubor do `.env` a vyplň hodnoty.
# `.env` je v .gitignore — necommituj ho.
# Next.js i drizzle-kit (přes dotenv) čtou ze stejného `.env`.
# ─────────────────────────────────────────────────────────────

# --- Databáze (Supabase Postgres) ---
# Connection stringy vezmi z dashboardu Supabase: Project → Connect.
# Heslo se speciálními znaky (@, :, /) musí být v URL percent-encodované (@ -> %40).
# POZOR na dva různé porty (stejný pooler host):
#   DATABASE_URL = Transaction pooler, port 6543 (běžné dotazy z appky)
#   DIRECT_URL   = Session pooler, port 5432 (migrace přes drizzle-kit)
# Pozn.: "Direct connection" (db.<ref>.supabase.co) je IPv6-only a z IPv4 sítí
# se nepřeloží — proto pro migrace používáme session pooler (5432), ne direct.
DATABASE_URL="postgresql://postgres.<ref>:<heslo>@aws-1-<region>.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.<ref>:<heslo>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Claude (generování draftů) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Resend (odesílání e-mailů) ---
RESEND_API_KEY=
# Odesílatel musí být na ověřené doméně v Resendu.
MAIL_FROM="Jméno <ahoj@tvojedomena.cz>"

# --- Google Places API (discovery) ---
GOOGLE_PLACES_API_KEY=

# --- PageSpeed Insights API (volitelné; když chybí, pagespeed = null) ---
PAGESPEED_API_KEY=

# --- Vercel (přehled projektů; volitelné) ---
# Token: vercel.com/account/tokens (read-only stačí). U týmu vyplň i VERCEL_TEAM_ID.
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# --- Telegram bot (webhook) ---
TELEGRAM_BOT_TOKEN=
# Náhodný tajný řetězec; posílá se Telegramu při registraci webhooku
# a ověřuje se v hlavičce X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
# Tvoje chat_id (whitelist pro bota). Uloží se i do app_user při seedu.
TELEGRAM_ALLOWED_CHAT_ID=
